{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "testRunner": "vitest",
  "reporters": ["clear-text", "progress", "json", "html"],
  "mutate": [
    "src/lib/filters.js",
    "src/lib/validation.js"
  ],
  "vitest": {
    "configFile": "vite.config.js"
  },
  "thresholds": {
    "high": 85,
    "low": 70,
    "break": 60
  }
}
